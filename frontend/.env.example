# EPC Intelligence Platform - Frontend Environment Variables
# Copy this file to .env.local and fill in your values

# Backend API URL
# For local development:
REACT_APP_API_URL=http://localhost:8000

# For production, use the deployed backend URL:
# REACT_APP_API_URL=https://epc-intelligence-api.onrender.com

# Application name (shown in header and browser title)
REACT_APP_APP_NAME=EPC Intelligence Platform

# Optional: Analytics or monitoring keys
# REACT_APP_ANALYTICS_KEY=your-key-here
