{
  "projectName": "epc-intelligence",
  "framework": "react",
  
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  
  "env": {
    "REACT_APP_API_URL": "@epc-intelligence-api-url",
    "REACT_APP_APP_NAME": "EPC Intelligence Platform"
  },
  
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://epc-intelligence-api.onrender.com/api/:path*"
    }
  ],
  
  "headers": [
    {
      "source": "/api/:path*",
      "headers": [
        {
          "key": "Access-Control-Allow-Credentials",
          "value": "true"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET,OPTIONS,PATCH,DELETE,POST,PUT"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "X-CSRF-Token, X-Requested-With, Accept, Accept-Version, Content-Length, Content-MD5, Content-Type, Date, X-Api-Version"
        }
      ]
    }
  ],
  
  "routes": [
    {
      "src": "^/api/.*",
      "methods": ["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS"],
      "dest": "https://epc-intelligence-api.onrender.com$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html",
      "status": 200
    }
  ]
}
